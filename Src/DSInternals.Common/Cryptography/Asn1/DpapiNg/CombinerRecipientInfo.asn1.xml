<?xml version="1.0" encoding="utf-8" ?>
<asn:Sequence
  xmlns:asn="http://schemas.dot.net/asnxml/201808/"
  name="CombinerRecipientInfo"
  namespace="DSInternals.Common.Cryptography.Asn1.DpapiNg">

  <!--
    CombinerRecipientInfo ::= SEQUENCE {
        version                 CMSVersion,
        recipientInfos          SEQUENCE SIZE (1..MAX) OF RecipientInfo,
        keyDerivationAlgorithm  AlgorithmIdentifier,
        keyEncryptionAlgorithm  AlgorithmIdentifier,
        encryptedKey            EncryptedKey
    }
  -->
  <asn:Integer name="Version" backingType="int" />
  <asn:SequenceOf name="RecipientInfos">
    <asn:AsnType typeName="DSInternals.Common.Cryptography.Asn1.Pkcs7.RecipientInfo" />
  </asn:SequenceOf>
  <asn:AsnType name="KeyDerivationAlgorithm" typeName="DSInternals.Common.Cryptography.Asn1.X509.AlgorithmIdentifier" />
  <asn:AsnType name="KeyEncryptionAlgorithm" typeName="DSInternals.Common.Cryptography.Asn1.X509.AlgorithmIdentifier" />
  <asn:OctetString name="EncryptedKey" />
</asn:Sequence>
